# SWE-RL environment config — source before launching training or eval.
# Usage: set -a; source .env.swe; set +a

# ── ECS Docker exec server URLs ──────────────────────────────────────
# 方案 A (localhost): http://localhost:5000
# 方案 B (4-GPU worker): http://<4GPU_WORKER_IP>:5000
# SWE_EXEC_SERVER_URLS="http://<4GPU_IP>:5000"
SWE_EXEC_SERVER_URLS="http://localhost:5000"


# ── Model checkpoint ─────────────────────────────────────────────────
HF_CKPT=/mnt/shared-storage-user/puyuan/code/slime/Qwen3-4B/

# ── Training data ────────────────────────────────────────────────────
PROMPT_DATA=/mnt/shared-storage-user/puyuan/code/OpenClaw-RL/swe-rl/swe_data/swe_gym_subset/train.jsonl

# ── Weights & Biases (optional) ──────────────────────────────────────
# WANDB_API_KEY=your_key_here
